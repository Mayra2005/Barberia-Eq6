function show(id) {

    document.querySelectorAll("section").forEach(
        s => s.classList.remove("active")
    );

    document.getElementById(id).classList.add("active");

}
function login() {

    const usuario = document.getElementById("usuario").value;
    const pass = document.getElementById("password").value;

    if (usuario === "" || pass === "") {
        alert("Debe llenar todos los campos");
        return;
    }

    let rol = "";

    // ASIGNACIÓN DE ROLES AUTOMÁTICA
    if (usuario.toLowerCase() === "dueño") rol = "Dueño";
    if (usuario.toLowerCase() === "barbero") rol = "Barbero";

    if (rol === "") {
        alert("Usuario no reconocido");
        return;
    }

    const menu = document.getElementById("menu");
    menu.innerHTML = "";

    document.getElementById("rolActual").innerText =
        "Rol activo: " + rol;

    if (rol === "Dueño") {

        menu.innerHTML += '<button onclick="show(\'empleados\')">Empleados</button>';
        menu.innerHTML += '<button onclick="show(\'promociones\')">Promociones</button>';
        menu.innerHTML += '<button onclick="show(\'pagos\')">Pagos</button>';
        menu.innerHTML += '<button onclick="show(\'respaldo\')">Respaldo</button>';
        menu.innerHTML += '<button onclick="logout()">Cerrar Sesión</button>';

        show("empleados");
    }

    if (rol === "Barbero") {

        menu.innerHTML += '<button onclick="show(\'citas\')">Agendar Cita</button>';
        menu.innerHTML += '<button onclick="show(\'modificar\')">Modificar Cita</button>';
        menu.innerHTML += '<button onclick="show(\'estilos\')">Estilos</button>';
        menu.innerHTML += '<button onclick="show(\'pagos\')">Registrar Pago</button>';
        menu.innerHTML += '<button onclick="logout()">Cerrar Sesión</button>';

        show("citas");
    }
}

function logout() {

    document.getElementById("menu").innerHTML = "";

    document.getElementById("rolActual").innerText =
        "Rol no autenticado";

    show("login");

}

function mensaje(texto) {

    alert(texto);

}
